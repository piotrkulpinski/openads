{
  "name": "openads",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:push": "bun run --cwd packages/db db:push",
    "db:reset": "bun run --cwd packages/db db:reset",
    "postinstall": "bun run db:generate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}