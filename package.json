{
  "name": "openads",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:push": "bun run --cwd packages/db db:push",
    "db:reset": "bun run --cwd packages/db db:reset",
    "postinstall": "bun run db:generate || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@dirstack/kodeks": "^1.1.2",
    "lefthook": "^2.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.11"
}
