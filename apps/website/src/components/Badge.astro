---
import type { HTMLAttributes } from "astro/types"

type Props = HTMLAttributes<"span">

const { class: className, ...props } = Astro.props
---

<span
  class:list={[
    "px-3 py-1 bg-background/50 font-medium text-xs -tracking-tight text-foreground/60 rounded-full",
    className,
  ]}
  {...props}
>
  <slot />
</span>
