---
import Button from "~/components/Button.astro"
import Orb from "~/components/Orb.astro"
---

<section class="relative overflow-clip py-20 md:py-28">
  <div
    class="relative max-w-3xl mx-auto px-6 flex flex-col items-center text-center gap-6 md:px-8"
    data-reveal
  >
    <h2
      class="text-3xl/tight font-semibold tracking-tight text-balance md:text-4xl/tight"
    >
      Your traffic. Your prices. Your&nbsp;advertisers.
    </h2>

    <p class="max-w-md text-base/relaxed text-foreground/55 text-pretty">
      Join the waitlist and be the first to know when we launch.
    </p>

    <Button href="#waitlist">Join the Waitlist</Button>
  </div>

  <Orb
    class="absolute top-[60%] left-1/2 -translate-x-1/2 -z-1 opacity-50"
  />
</section>
